import os
import cv2
import dlib
import numpy as np
import tensorflow as tf
import torch
import torch.nn as nn
from torchvision import transforms, models
from collections import deque
import threading
import queue
import time

# ────────────────────────────────────────────────
# 설정값
# ────────────────────────────────────────────────
PREDICTOR_PATH = "shape_predictor_68_face_landmarks.dat"
DROWSY_MODEL_PATH = "drowsiness_mobilenet_final.h5"
ATTR_MODEL_PATH = "head_mask_sunglass_mobilenetv3.pt"
EYE_AR_THRESH = 0.21
YAW_THRESH = 25
PITCH_THRESH = 20
WINDOW_NAME = "Driver Monitor AI v6 - 멀티 속성 분석"
FRAME_SKIP = 2

# ────────────────────────────────────────────────
# 모델 준비
# ────────────────────────────────────────────────
detector = dlib.get_frontal_face_detector()
predictor = dlib.shape_predictor(PREDICTOR_PATH)
drowsy_model = tf.keras.models.load_model(DROWSY_MODEL_PATH)

# 속성 모델 (head pose, mask, sunglasses)
attr_model = None
attr_transform = None
device = torch.device("cuda" if torch.cuda.is_available() else "cpu")

if os.path.exists(ATTR_MODEL_PATH) and os.path.getsize(ATTR_MODEL_PATH) > 1000:
    try:
        attr_model = models.mobilenet_v3_small(pretrained=False)
        num_ftrs = attr_model.classifier[3].in_features
        attr_model.classifier[3] = nn.Linear(num_ftrs, 7)
        attr_model.load_state_dict(torch.load(ATTR_MODEL_PATH, map_location=device))
        attr_model.to(device)
        attr_model.eval()
        attr_transform = transforms.Compose([
            transforms.ToPILImage(),
            transforms.Resize((224,224)),
            transforms.ToTensor(),
            transforms.Normalize(mean=[0.485,0.456,0.406], std=[0.229,0.224,0.225])
        ])
        print("✅ 속성 분류 모델 로드 완료")
    except Exception as e:
        print("⚠️ 속성 모델 로드 실패 → 스킵", e)
else:
    print("⚠️ 속성 모델 파일 없음 → 속성 분석 스킵")

